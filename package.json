{
  "name": "internship-management-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:gas": "npm run build && node scripts/prepare-gas.mjs",
    "gas:login": "npx clasp -P appscript -I appscript login",
    "gas:status": "npx clasp -P appscript -I appscript status",
    "gas:push": "npm run build:gas && npx clasp -P appscript -I appscript push --force",
    "gas:deploy": "npm run build:gas && npx clasp -P appscript -I appscript push --force && npx clasp -P appscript -I appscript deploy",
    "gas:open": "npx clasp -P appscript -I appscript open",
    "push:gas": "npm run gas:push",
    "deploy:gas": "npm run gas:push",
    "release:gas": "npm run gas:deploy"
  },
  "devDependencies": {
    "@google/clasp": "^3.0.6",
    "@tailwindcss/postcss": "^4.1.4",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "svelte": "^5.53.12",
    "tailwindcss": "^4.1.4",
    "tw-animate-css": "^1.3.0",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "lucide-svelte": "^1.0.1"
  }
}
